<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>Crystal Agent Report - {{ project_id }}</title>
  <style>
    body { font-family: Arial, sans-serif; margin: 2rem; color: #1f2933; }
    table { border-collapse: collapse; width: 100%; margin-top: 1rem; }
    th, td { border: 1px solid #cbd5e1; padding: 0.5rem; text-align: left; }
    th { background: #e2e8f0; }
    .continue { color: #166534; font-weight: bold; }
    .review { color: #92400e; font-weight: bold; }
  </style>
</head>
<body>
  <h1>Crystal Agent Report</h1>
  <p><strong>Project:</strong> {{ project_id }}</p>
  <table>
    <thead>
      <tr>
        <th>Rank</th>
        <th>Candidate</th>
        <th>Score</th>
        <th>Recommendation</th>
        <th>TFZ</th>
        <th>LLG</th>
        <th>Rwork</th>
        <th>Rfree</th>
        <th>Reasons</th>
      </tr>
    </thead>
    <tbody>
      {% for candidate in candidates %}
      <tr>
        <td>{{ loop.index }}</td>
        <td>{{ candidate.candidate_id }}</td>
        <td>{{ candidate.score }}</td>
        <td class="{{ candidate.recommendation }}">{{ candidate.recommendation }}</td>
        <td>{{ candidate.tfz if candidate.tfz is not none else "" }}</td>
        <td>{{ candidate.llg if candidate.llg is not none else "" }}</td>
        <td>{{ candidate.final_rwork if candidate.final_rwork is not none else "" }}</td>
        <td>{{ candidate.final_rfree if candidate.final_rfree is not none else "" }}</td>
        <td>{{ candidate.reasons | join("; ") }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
</body>
</html>
